# Environment configuration
#
# DATABASE_URL should point to Supabase Postgres in production.
# SESSION_SECRET is used by express-session; set a strong value.

DATABASE_URL=postgresql://postgres:password@localhost:5432/placement_db
SESSION_SECRET=replace_with_long_random_secret
PORT=3000

# Optional: override seeded showcase passwords
DEMO_ADMIN_PASSWORD=Admin@123
DEMO_EMPLOYER_PASSWORD=Employer@123
DEMO_STUDENT_PASSWORD=Student@123
